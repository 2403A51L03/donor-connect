{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "node artifacts/api-server/dist/index.cjs",
    "dev": "node -r dotenv/config ./dev-start.js",
    "seed:db": "pnpm --filter @workspace/api-server exec tsx ./seed-db.ts",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:prod": "pnpm --filter @workspace/blood-donor build && pnpm --filter @workspace/api-server build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5"
  }
}
