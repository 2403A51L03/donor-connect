# Database Configuration
# Get this from: https://supabase.com/dashboard → Project Settings → Database → Connection Pooling
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# Server Configuration
# These are automatically set by Render, use defaults for local development
PORT=5000
API_PORT=5000

# Frontend Configuration
BASE_PATH=/

# Environment
NODE_ENV=development
